              "fieldId": "resumo_solicitacao",
              "fieldValue": "={{ $json.summary }}"
            },
            {
              "fieldId": "ultima_interacao",
              "fieldValue": "={{ $json.ultima_interacao }}"
            }
          ]
        }
      },
      "id": "supabase-update",
      "name": "Supabase - Update Kanban",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
