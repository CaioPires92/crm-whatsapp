        "options": {
          "temperature": 0.4
        }
      },
      "id": "openai-chat-model",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        2260,
        540
      ],
      "notesInFlow": true,
      "notes": "ADICIONADO: modelo de chat do agente."
    },
    {
      "parameters": {
