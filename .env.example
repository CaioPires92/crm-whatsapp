# AUTHENTICATION_API_KEY=sua-chave
AUTHENTICATION_API_KEY=

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:postgres@postgres:5432/evolution

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

CONFIG_SESSION_PHONE_VERSION=2.3000.1035194821

QRCODE_LIMIT=30
QRCODE_COLOR=#175197

OPEN_IAPIKEY=

EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=delplata2026
EVOLUTION_API_KEY=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Hospedin overrides for automatic availability checks
HOSPEDIN_ENABLED=false
HOSPEDIN_API_BASE_URL=https://pms.hospedin.com/api/v2
HOSPEDIN_ACCOUNT_SLUG=
HOSPEDIN_TIMEOUT_MS=10000
HOSPEDIN_FALLBACK_MESSAGE=No momento nao consegui confirmar a disponibilidade em tempo real. Posso seguir com a cotacao e a equipe confirma manualmente.
# JSON object or simple string map:
# HOSPEDIN_ROOM_MAPPINGS={"Chale/Anexo":"123","Apto Terreo":"456","Apto Superior":"789"}
HOSPEDIN_ROOM_MAPPINGS=

# Evolution API Persistence
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_CONTACTS=true
