{
  "name": "Hotel CRM - Kanban Automation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "evolution-webhook",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook Evolution",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        220,
        320
      ],
      "webhookId": "hotel-crm-evolution-webhook",
      "notesInFlow": true,
      "notes": "Recebe os eventos da Evolution API."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "filter-event",
              "leftValue": "={{ ($json.body?.event || $json.event || 'messages.upsert').toLowerCase() }}",
              "rightValue": "messages.upsert",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "filter-fromme",
              "leftValue": "={{ $json.body?.data?.key?.fromMe ?? $json.data?.key?.fromMe ?? false }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "false",
                "singleValue": true
              }
            },
            {
              "id": "filter-group",
              "leftValue": "={{ (($json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '').endsWith('@g.us')) }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "false",
                "singleValue": true
              }
            },
            {
              "id": "filter-newsletter",
              "leftValue": "={{ (($json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '').includes('@newsletter')) }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "false",
                "singleValue": true
              }
            },
            {
              "id": "filter-status",
              "leftValue": "={{ ($json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '') }}",
              "rightValue": "status@broadcast",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            },
            {
              "id": "filter-text",
              "leftValue": "={{ !!($json.body?.data?.message?.conversation || $json.data?.message?.conversation || $json.body?.data?.message?.extendedTextMessage?.text || $json.data?.message?.extendedTextMessage?.text || $json.body?.data?.message?.imageMessage?.caption || $json.data?.message?.imageMessage?.caption) }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "message-filter",
      "name": "Filtro Entrada WhatsApp",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.1,
      "position": [
        440,
        320
      ],
      "notesInFlow": true,
      "notes": "ADICIONADO: ignora grupos, newsletter, status e mensagens enviadas pela propria instância."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "lead-remotejid",
              "name": "remoteJid",
              "value": "={{ $json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '' }}",
              "type": "string"
            },
            {
              "id": "lead-number",
              "name": "waNumber",
              "value": "={{ (($json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '').split('@')[0]) }}",
              "type": "string"
            },
            {
              "id": "lead-name",
              "name": "pushName",
              "value": "={{ $json.body?.data?.pushName || $json.data?.pushName || 'Sem nome' }}",
              "type": "string"
            },
            {
              "id": "lead-instance",
              "name": "instanceName",
              "value": "={{ $json.body?.instance || $json.instance || 'SUA_INSTANCIA' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "normalize-lead",
      "name": "Normalizar Lead",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        320
      ],
      "notesInFlow": true,
      "notes": "ADICIONADO: padroniza remoteJid, numero sem sufixo e nome do lead para o restante do fluxo."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "message-text",
              "name": "messageText",
              "value": "={{ $json.body?.data?.message?.conversation || $json.data?.message?.conversation || $json.body?.data?.message?.extendedTextMessage?.text || $json.data?.message?.extendedTextMessage?.text || $json.body?.data?.message?.imageMessage?.caption || $json.data?.message?.imageMessage?.caption || '' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "normalize-message",
      "name": "Normalizar Mensagem",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        880,
        320
      ],
      "notesInFlow": true,
      "notes": "ADICIONADO: extrai o texto da mensagem para o agente ler sempre do mesmo campo."
    },
    {
      "parameters": {
        "operation": "get",
        "tableId": "kanban_cards",
        "filters": {
          "conditions": [
            {
              "keyName": "lead_id",
              "keyValue": "={{ $('Normalizar Lead').item.json.remoteJid }}"
            }
          ]
        }
      },
      "id": "supabase-get",
      "name": "Supabase - Get Lead Stage",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1320,
        320
      ],
      "alwaysOutputData": true,
      "notesInFlow": true,
      "notes": "AJUSTADO: usa o formato atual do node Supabase (tableId, keyName, keyValue)."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "lead-exists",
              "leftValue": "={{ $json.id || $json.lead_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "exists",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-lead-exists",
      "name": "Lead Existe?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.1,
      "position": [
        1540,
        320
      ],
      "notesInFlow": true,
      "notes": "ADICIONADO: se o card nao existir, cria um registro inicial no Kanban antes de conversar."
    },
    {
      "parameters": {
        "tableId": "kanban_cards",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "lead_id",
              "fieldValue": "={{ $('Normalizar Lead').item.json.remoteJid }}"
            },
            {
              "fieldId": "hospede_nome",
              "fieldValue": "={{ $('Normalizar Lead').item.json.pushName }}"
            },
            {
              "fieldId": "etapa",
              "fieldValue": "Novo Lead"
